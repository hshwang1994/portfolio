    clusterBorder: '#CBD5E1'
---
flowchart TB
    REQ(["<b>개발 요청</b> · 사용자 지시 또는 dev 브랜치 머지"]):::start
    AI@{ icon: "logos:claude-icon", label: "AI(Claude Code)가 코드 작성" }

    subgraph GATE["검증 게이트 — 커밋 전 차단 · 머지 후 보고"]
      direction TB
      G1{"변경 영향 미리보기? · 영향 모듈 · 고객사 · 리스크"}:::gate
      G2{"커밋 전 검사 (pre-commit) · 시크릿 · 보호 경로 · 고객사 경계 위반?"}:::gate
      G3["머지 후 점검 (post-merge) · 스케줄러 · Flyway · 외부 enum 자동 보고"]:::act
      G1 -->|"통과"| G2
    end

    SHIP(["커밋 · 머지 · 배포"]):::ok
    FIX@{ icon: "fa6-solid:user", label: "위반 시 사람이 확인 · 수정" }

    subgraph ASSET["공유 검증 자산 — 사람이 읽는 의도를 자동 강제로"]
      direction TB
      RULES["규칙 34종 (.md)"]:::ext
      POLICY["정책 12종 (.yaml) · 고객사 경계 · 보호 경로"]:::ext
      HOOK["git hook 29개 (.py) · pre-commit · commit-msg · post-merge"]:::ext
      AIA["skill · agent · 작업 절차서와 역할별 AI 작업자"]:::ext
    end

    FP[("기록 · FAILURE_PATTERNS · ADR · CONVENTION_DRIFT · append-only")]:::ext
    EVO["사고를 규칙 · 정책 · hook으로 환원 (closed-loop)"]:::act

    REQ --> AI --> G1
    G2 -->|"통과"| SHIP --> G3
    G1 -->|"위반 · HIGH 리스크"| FIX
    G2 -->|"위반"| FIX
    FIX -.->|"고친 뒤 다시"| G1
    HOOK -.->|"게이트가 자산 로드해 검사"| G2
    G3 -->|"사고 · 회귀 기록"| FP
    FP --> EVO --> HOOK
    EVO ==>|"다음 변경부터 같은 유형 자동 차단"| G2

    classDef start fill:#DBEAFE,stroke:#3B82F6,color:#1E293B,stroke-width:1.5px
    classDef act   fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:1.5px
    classDef ok    fill:#DCFCE7,stroke:#16A34A,color:#1E293B,stroke-width:1.5px
    classDef gate  fill:#FEF9C3,stroke:#CA8A04,color:#1E293B,stroke-width:1.5px
    classDef stop  fill:#FFE4E6,stroke:#E11D48,color:#1E293B,stroke-width:1.5px
    classDef ext   fill:#F0F9FF,stroke:#0EA5E9,color:#1E293B,stroke-width:1.5px
