---
title: 코드 합친 직후 자동 점검 보고서 + 후속 작업 (post-merge)
config:
  layout: elk
  look: neo
  theme: base
  themeVariables:
    fontFamily: 'Malgun Gothic, Pretendard, Noto Sans KR, sans-serif'
    fontSize: '16px'
    primaryColor: '#EEF2FF'
    primaryTextColor: '#1E293B'
    primaryBorderColor: '#6366F1'
    lineColor: '#64748B'
    edgeLabelBackground: '#FFFFFF'
---
flowchart TD
    START(["git merge · pull · rebase 직후"]):::start
    HOOK["post-merge git hook 자동 실행"]:::act
    SCAN["AI가 만든 코드 8종 자동 점검<br/>스케줄러 try-catch · 의심 패턴 · Flyway 중복 · i18n 키 등"]:::act
    REPORT["보고서 자동 작성 → docs/ai/incoming-review"]:::act
    JUDGE{"HIGH 위반 1건 이상?"}:::gate
    CLEAN(["clean — 위반 없음 (비즈니스 로직은 사람 교차 확인)"]):::ok
    HIGH(["HIGH — 후속 작업 티켓 등록 (머지는 차단 안 함, advisory)"]):::stop
    DEV@{ icon: "fa6-solid:user", label: "사람이 검토 (자동 수정 금지)" }
    FP[("사고 기록 → 규칙 · hook 환원 (closed-loop)")]:::ext

    START --> HOOK --> SCAN --> REPORT --> JUDGE
    JUDGE -- "아니오" --> CLEAN
    JUDGE -- "예" --> HIGH --> DEV --> FP
    FP -.->|"다음 머지부터 점검 강화"| HOOK

    classDef start fill:#F1F5F9,stroke:#94A3B8,color:#1E293B,stroke-width:2px
    classDef act   fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:2px
    classDef ok    fill:#ECFDF5,stroke:#10B981,color:#1E293B,stroke-width:2px
    classDef gate  fill:#FFFBEB,stroke:#F59E0B,color:#1E293B,stroke-width:2px
    classDef stop  fill:#FFF1F2,stroke:#F43F5E,color:#1E293B,stroke-width:2px
    classDef ext   fill:#F0F9FF,stroke:#0EA5E9,color:#1E293B,stroke-width:2px
