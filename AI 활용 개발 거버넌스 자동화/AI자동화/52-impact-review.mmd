---
title: 바꾸기 전에 영향을 미리 보고, 위험도로 길을 나눈다
config:
  layout: elk
  look: neo
  theme: base
  themeVariables:
    fontFamily: 'Malgun Gothic, Pretendard, Noto Sans KR, sans-serif'
    fontSize: '16px'
    primaryColor: '#EEF2FF'
    primaryTextColor: '#1E293B'
    primaryBorderColor: '#6366F1'
    lineColor: '#64748B'
    edgeLabelBackground: '#FFFFFF'
---
flowchart TD
    REQ(["코드 변경 요청 (기능 추가 · 수정 · 리팩토링 · 마이그레이션)"]):::start

    SKIP{"단순 변경이거나 '그냥 진행해줘' 명시?"}:::gate

    DEV@{ icon: "fa6-solid:user", label: "개발자가 변경 요청" }

    PREVIEW@{ icon: "logos:claude-icon", label: "AI가 변경 전 영향 프리뷰 (task-impact-preview)" }

    subgraph SCAN ["AI가 실측 스캔하는 5가지 항목"]
        direction TB
        S1["1. 영향 모듈 — clovircm-domain · clovircm-web 등 파일 경로 수준"]:::act
        S2["2. 영향 고객사 — core면 6개 고객사 전체, plugin이면 해당 고객사만"]:::act
        S3["3. 함께 바뀔 것 — Spock · Playwright 테스트, docs/ai 문서, plugin 이벤트 구독자"]:::act
        S4["4. 외부연동 enum 확인 — Jenkins · VMware · GitLab 지원값은 사람 확인 필요"]:::ext
        S5["5. 리스크 top 3 — FAILURE_PATTERNS 과거 사례 + 일반 리스크"]:::act
    end

    SRC@{ icon: "fa6-solid:database", label: "customer-boundary-map · FAILURE_PATTERNS · test-selection-map" }

    JUDGE{"위험도 등급?"}:::gate

    LOW(["낮음 — 바로 구현 (implement-safe-change)"]):::ok
    MED["보통 — 대안 비교 후 진행 (compare-feature-options)"]:::gate
    HIGH["높음 — 상세 브리핑 작성 (write-impact-brief)"]:::stop
    CRIT["치명 — 고객사 경계 · 배포 · DB DDL 변경"]:::stop

    APPROVE@{ icon: "fa6-solid:user", label: "담당자가 명시 승인해야 진입" }

    GO(["승인 후 구현 시작"]):::ok
    BYPASS(["프리뷰 건너뛰고 바로 구현"]):::start

    REQ --> DEV --> SKIP
    SKIP -- "예" --> BYPASS
    SKIP -- "아니오" --> PREVIEW
    PREVIEW --> SCAN
    SRC -.->|실측 데이터| SCAN
    SCAN --> JUDGE
    JUDGE -- "낮음" --> LOW
    JUDGE -- "보통" --> MED
    JUDGE -- "높음" --> HIGH
    JUDGE -- "치명" --> CRIT
    HIGH --> APPROVE
    CRIT --> APPROVE
    MED --> GO
    APPROVE --> GO

    classDef start fill:#F1F5F9,stroke:#94A3B8,color:#1E293B,stroke-width:2px
    classDef act   fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:2px
    classDef ok    fill:#ECFDF5,stroke:#10B981,color:#1E293B,stroke-width:2px
    classDef gate  fill:#FFFBEB,stroke:#F59E0B,color:#1E293B,stroke-width:2px
    classDef stop  fill:#FFF1F2,stroke:#F43F5E,color:#1E293B,stroke-width:2px
    classDef ext   fill:#F0F9FF,stroke:#0EA5E9,color:#1E293B,stroke-width:2px
