---
title: 운영 Jenkins 마스터 장애 시 대기 마스터가 무중단 인수?
config:
  layout: elk
  look: neo
  theme: base
  themeVariables:
    fontFamily: 'Malgun Gothic, Pretendard, Noto Sans KR, sans-serif'
    fontSize: '16px'
    primaryColor: '#EEF2FF'
    primaryTextColor: '#1E293B'
    primaryBorderColor: '#6366F1'
    lineColor: '#64748B'
    edgeLabelBackground: '#FFFFFF'
---
flowchart TD
    NORMAL(["평소 — 운영 Jenkins 마스터가 단독 활성"]):::start
    ACTIVE@{ icon: "logos:jenkins", label: "운영 Jenkins 마스터 (Active) · Job 스케줄링 · 파라미터 전달" }
    STATE@{ icon: "logos:redis", label: "Redis · 빌드 상태 · 큐 공유" }
    FAIL{"운영 마스터 장애 발생?"}:::gate
    DETECT{"헬스체크가 장애 감지?"}:::gate
    FENCE["Fencing · 중복 활성 차단 (split-brain 방지)"]:::stop
    PROMOTE["대기 마스터 (Standby) 를 Active 로 승격"]:::act
    STANDBY@{ icon: "logos:jenkins", label: "대기 Jenkins 마스터 (Standby → Active)" }
    INHERIT["Redis 공유 상태 인수 · 진행 중 Job 큐 그대로 복원"]:::act
    GITLAB@{ icon: "logos:gitlab", label: "GitLab 재연결 · HTTPS (443) checkout" }
    AGENTS@{ icon: "fa6-solid:server", label: "러너 지역 A·B·C 재연결 (SSH 22)" }
    RESUME(["무중단 재개 — 설정과 이력 그대로"]):::ok

    NORMAL --> ACTIVE
    ACTIVE -->|"빌드 상태 기록"| STATE
    ACTIVE --> FAIL
    FAIL -- "예" --> DETECT
    FAIL -- "아니오 — 정상 운영" --> ACTIVE
    DETECT -- "감지" --> FENCE
    FENCE --> PROMOTE --> STANDBY
    STANDBY --> INHERIT
    STATE -.->|"공유 상태 읽기"| INHERIT
    INHERIT --> GITLAB
    INHERIT --> AGENTS
    GITLAB --> RESUME
    AGENTS --> RESUME

    classDef start fill:#F1F5F9,stroke:#94A3B8,color:#1E293B,stroke-width:2px
    classDef act   fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:2px
    classDef ok    fill:#ECFDF5,stroke:#10B981,color:#1E293B,stroke-width:2px
    classDef gate  fill:#FFFBEB,stroke:#F59E0B,color:#1E293B,stroke-width:2px
    classDef stop  fill:#FFF1F2,stroke:#F43F5E,color:#1E293B,stroke-width:2px
    classDef ext   fill:#F0F9FF,stroke:#0EA5E9,color:#1E293B,stroke-width:2px
