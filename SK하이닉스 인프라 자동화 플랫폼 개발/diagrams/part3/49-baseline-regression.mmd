---
title: 바뀐 코드를 기준값과 자동 비교, 버그면 배포 차단
config:
  layout: elk
  look: neo
  theme: base
  themeVariables:
    fontFamily: 'Pretendard, Malgun Gothic, Noto Sans KR, sans-serif'
    fontSize: '14px'
    primaryTextColor: '#1E293B'
    lineColor: '#64748B'
    edgeLabelBackground: '#FFFFFF'
    clusterBkg: '#F8FAFC'
    clusterBorder: '#CBD5E1'
---
flowchart TD
    CHANGE(["코드와 규칙 변경"]):::input
    TEST@{ icon: "logos:python", label: "자동 테스트 실행 (Python)" }
    CMP{"기준값과 일치?"}:::warn
    PASS(["일치, 배포 허용"]):::ok
    DIFF{"차이 원인?"}:::warn
    EXT(["외부 변경, 기준값 갱신"]):::proc
    BUG(["코드 버그, 배포 차단 후 수정"]):::fail

    CHANGE --> TEST --> CMP
    CMP -- "일치" --> PASS
    CMP -- "불일치" --> DIFF
    DIFF -- "외부 변경" --> EXT --> PASS
    DIFF -- "코드 버그" --> BUG --> CHANGE

    TEST:::proc

    subgraph LEGEND["범례"]
      direction LR
      LG_A["입력"]:::input
      LG_B["처리"]:::proc
      LG_C["통과, 출력"]:::ok
      LG_D["주의, 분기"]:::warn
      LG_E["실패, 차단"]:::fail
    end

    classDef input fill:#F1F5F9,stroke:#94A3B8,color:#1E293B,stroke-width:1.5px
    classDef proc  fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:1.5px
    classDef ok    fill:#ECFDF5,stroke:#10B981,color:#1E293B,stroke-width:1.5px
    classDef warn  fill:#FFFBEB,stroke:#F59E0B,color:#1E293B,stroke-width:1.5px
    classDef fail  fill:#FFF1F2,stroke:#F43F5E,color:#1E293B,stroke-width:1.5px
