flowchart TD
    IN(["IP 하나 + 대상 종류 입력"]):::start
    PICK{"대상 종류로 점검 방법 선택"}:::gate
    OS@{ icon: "fa6-solid:desktop", label: "운영체제 점검 (윈도우/리눅스)" }
    ESXI@{ icon: "logos:vmware", label: "가상화 점검 (vSphere)" }
    HW@{ icon: "fa6-solid:server", label: "서버 하드웨어 점검" }
    STD(["표준 형식 결과<br/>성공이든 실패든 같은 구조"]):::ok

    IN --> PICK
    PICK -- "서버 OS" --> OS --> STD
    PICK -- "가상화" --> ESXI --> STD
    PICK -- "하드웨어" --> HW --> STD

    classDef start fill:#F1F5F9,stroke:#94A3B8,color:#1E293B,stroke-width:2px
