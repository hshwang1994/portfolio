    ROUTE -->|"loc = B · SSH(22)"| RB
    ROUTE -->|"loc = C · SSH(22)"| RC
    RA -->|"SSH / WinRM / HTTPS"| TARGET
    RB --> TARGET
    RC --> TARGET
    ROUTE -.-> NOTE

    classDef act   fill:#EEF2FF,stroke:#6366F1,color:#1E293B,stroke-width:1.5px
