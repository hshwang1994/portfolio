  end

  BRIDGE{{"폐쇄망 자동화<br/>플랫폼 구축"}}:::axis

  subgraph TOBE["TO-BE · 도입 후 (자동화 플랫폼)"]
    direction TB
    B1["포털 클릭 한 번 자동 점검, 운영"]:::good
